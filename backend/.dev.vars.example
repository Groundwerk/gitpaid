# Encryption key for JWT sessions (e.g. any random 32-character string)
JWT_SECRET=local-jwt-development-secret-key-12345

# Google Developer Console OAuth Client ID
GOOGLE_CLIENT_ID=123456789-placeholder.apps.googleusercontent.com

# Google Developer Console OAuth Client Secret for Gmail API refreshes
GMAIL_CLIENT_SECRET=

# Enable mock auth bypass for testing without Google credentials (set to "true" only locally)
ALLOW_MOCK_LOGIN=true
